<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 中奖 -->
    <item android:state_selected="true">
        <shape>
            <solid android:color="#1A04D5D5"/>
            <stroke
                android:width="1dp"
                android:color="#04D5D5"/>
            <corners android:radius="30dp"/>
        </shape>
    </item>

    <!-- 不可点击 -->
    <item android:state_enabled="false">
        <shape>
            <solid android:color="@color/color_guessing_bet_disabled"/>
            <stroke
                android:width="1dp"
                android:color="#DDDDDD"/>
            <corners android:radius="30dp"/>
        </shape>
    </item>

    <!-- 按下 -->
    <item android:state_pressed="true">
        <shape>
            <solid android:color="@color/color_guessing_bet_pressed"/>
            <stroke
                android:width="1dp"
                android:color="#04D5D5"/>
            <corners android:radius="30dp"/>
        </shape>
    </item>

    <!-- 默认 -->
    <item>
        <shape>
            <solid android:color="@color/color_guessing_bet_normal"/>
            <stroke
                android:width="1dp"
                android:color="#DDDDDD"/>
            <corners android:radius="30dp"/>
        </shape>
    </item>

</selector>