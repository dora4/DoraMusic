<?xml version="1.0" encoding="utf-8"?>

<dora.widget.DoraMarkView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/mv_guessing_item"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/shape_guessing_item_border"
    android:layout_margin="5dp">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">
        <!-- 标题 -->
        <TextView
            android:id="@+id/tv_guessing_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="50dp"
            android:textSize="15sp"
            android:textColor="@color/colorPrimary"/>

        <!-- 时间 + 状态 -->
        <TextView
            android:id="@+id/tv_guessing_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:layout_marginTop="4dp"
            android:textColor="@color/colorTextSecondary"/>

        <dora.widget.FlowLayout
            android:id="@+id/fl_options"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"/>
    </LinearLayout>
</dora.widget.DoraMarkView>