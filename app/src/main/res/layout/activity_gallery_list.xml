<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    tools:context=".score.GalleryListActivity">

    <data>

    </data>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/colorPanelBg">

        <View
            android:id="@+id/statusbar_gallery_list"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:background="@color/skin_theme_color" />
        <dora.widget.DoraTitleBar
            android:id="@+id/titlebar_gallery_list"
            android:layout_width="match_parent"
            android:layout_height="45dp"
            app:dview_title="@string/my_gallery"
            app:dview_backIconTint="@color/white"
            android:background="@color/skin_theme_color"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="10dp"/>

    </LinearLayout>

</layout>